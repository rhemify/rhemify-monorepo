{
  "name": "rhemify-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @rhemify-monorepo/db db:push",
    "db:studio": "turbo -F @rhemify-monorepo/db db:studio",
    "db:generate": "turbo -F @rhemify-monorepo/db db:generate",
    "db:migrate": "turbo -F @rhemify-monorepo/db db:migrate",
    "db:local": "turbo -F @rhemify-monorepo/db db:local",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@rhemify-monorepo/env": "workspace:*",
    "convex": "^1.34.1",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rhemify-monorepo/config": "workspace:*",
    "@solana/kit": "^6.7.0",
    "@solana/mpp": "^0.5.1",
    "@types/node": "catalog:",
    "mppx": "^0.5.9",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "x402-fetch": "^1.1.0",
    "x402-solana": "^2.0.4"
  },
  "packageManager": "bun@1.3.11"
}
