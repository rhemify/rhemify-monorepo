{
  "name": "rhemify-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "better-auth": "1.5.5",
      "convex": "^1.34.1",
      "@convex-dev/better-auth": "^0.11.3",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:backend": "turbo -F @rhemify-monorepo/backend dev",
    "dev:setup": "turbo -F @rhemify-monorepo/backend dev:setup",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@rhemify-monorepo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rhemify-monorepo/config": "workspace:*",
    "@types/node": "catalog:",
    "esbuild": "^0.28.0",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
